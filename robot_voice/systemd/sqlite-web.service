[Unit]
Description=SQLite Web — browse trainer.db (debug UI)
After=network.target

[Service]
Type=simple
User=phuong
WorkingDirectory=/home/phuong/robot_voice
ExecStart=/home/phuong/robot_voice/.venv/bin/sqlite_web \
    --host 0.0.0.0 \
    --port 8081 \
    --no-browser \
    /home/phuong/robot_voice/data/trainer.db
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=sqlite-web

[Install]
WantedBy=multi-user.target
